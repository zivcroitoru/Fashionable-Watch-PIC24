        "linker.oXC16ld-stackguard": "16",
        "linker.remove-unused-sections": false,
        "linker.report-memory-usage": true,
        "linker.secure-eeprom": "no_eeprom",
        "linker.secure-flash": "no_flash",
        "linker.secure-ram": "no_ram",
        "linker.secure-write-protect": "no_write_protect",
