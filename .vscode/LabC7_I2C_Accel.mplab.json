{
  "version": "1.8",
  "importedFrom": "./",
  "configurations": [
    {
      "name": "default",
      "id": "conf1",
      "device": "PIC24FJ256GA705",
      "imageType": "application",
      "imagePath": "./out/LabC7_I2C_Accel/default.elf",
      "toolProperties": "default-tool",
      "tool": "PKOBSKDEPlatformTool",
      "packs": [
        {
          "name": "PIC24F-GA-GB_DFP",
          "vendor": "Microchip",
          "version": "1.4.141"
        }
      ],
      "fileSet": "Project files",
      "toolchain": "default-XC16"
    }
  ],
  "propertyGroups": [
    {
      "name": "default-XC16",
